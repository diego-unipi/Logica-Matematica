# Ignore everything by default.
*

# Re-include directories so whitelist rules can be applied.
!*/

# Keep essential repo files.
!.gitignore
!README.md

# Keep GitHub configuration files.
!.github/
!.github/**

# Keep TeX files at repository root.
!/*.tex

# Keep TeX files inside Sezioni.
!Sezioni/**/*.tex

# Keep bibliography and style files at repository root.
!/*.bib
!/*.sty
!/*.cls

# Keep the images folder and all its contents.
!Immagini/
!Immagini/**

# Keep only source files in Git; the compiled main PDF is generated in CI.
Appunti di Logica Matematica.pdf
Typo.pdf
build/Appunti di Logica Matematica.pdf
